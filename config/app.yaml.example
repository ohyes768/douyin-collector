# douyin-collector 应用配置示例
# 复制此文件为 app.yaml 并修改相应配置

app:
  # 服务器配置
  server:
    url: "http://your-server-ip:8000"    # 修改为你的服务器地址
    timeout: 300                          # 上传超时（秒）
    check_endpoint: "/api/check/{filename}"
    upload_endpoint: "/upload"

  # Cookie 配置
  cookie:
    path: "config/cookie.yaml"

  # 采集配置
  collector:
    days_limit: 7              # 默认最近 7 天
    max_videos: 0              # 0 表示不限制
    max_file_size: 104857600   # 100MB
    exclude_products: true     # 排除商品视频

  # 下载配置
  download:
    cache_dir: "cache/videos"
    chunk_size: 1048576        # 1MB
    timeout: 300

  # 处理配置
  processing:
    max_retries: 3             # 最大重试次数
    retry_delay: 5             # 重试延迟（秒）
    serial: true               # 串行处理

  # 通知配置
  notification:
    enabled: true              # 是否启用通知
    dingtalk_webhook: "https://oapi.dingtalk.com/robot/send?access_token=YOUR_TOKEN"  # 钉钉机器人 Webhook URL

  # 日志配置
  logging:
    level: "INFO"
    console: true
    file: true
    dir: "logs"
